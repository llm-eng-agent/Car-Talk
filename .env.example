# Car-Talk environment variables (names only — never commit real values).
# Copy to .env and fill in. .env is git-ignored.

# --- OpenAI (paid) — used by the offline pipeline (embeddings) and online app (generation)
# Not required for Spike A scraping.
OPENAI_API_KEY=

# --- Qdrant Cloud — vector storage and hybrid retrieval (later phases)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=car_review_chunks_v1

# --- Upstash Redis — rate limiting only, never conversational memory (online app)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# HMAC key used to hash forwarded IPs for rate-limit identifiers (raw IP is never stored).
RATE_LIMIT_SECRET=
